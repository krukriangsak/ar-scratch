rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DEVELOPMENT RULES — สำหรับทดสอบระบบผ่าน VS Code และ GitHub Pages
    // เปิดอ่าน/เขียนทุก collection ชั่วคราว เพื่อแก้ Missing or insufficient permissions
    // ห้ามใช้เก็บข้อมูลส่วนบุคคลสำคัญ และควรเปลี่ยนเป็นกฎที่ใช้ Authentication ภายหลัง
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
