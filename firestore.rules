rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // รุ่น School Demo: ไม่ใช้ Firebase Authentication
    // เหมาะสำหรับงานทดลองในชั้นเรียนและ GitHub Pages
    match /schools/{schoolId}/players/{playerId} {
      allow read, create, update, delete: if true;
    }
    match /schools/{schoolId}/events/{eventId} {
      allow read, create: if true;
      allow update, delete: if false;
    }
    match /schools/{schoolId}/system/{docId} {
      allow read, write: if true;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
